 entities: names, dates, amounts, invoice numbers.\n\nFormat your result EXACTLY like this:\n---\n**Extraction Results: [filename]**\n[Summary]\n[Entities]\n---\n\n**STEP 5 — Create Confluence Page**\nUse the Confluence POST tool to create a page containing the text. \n\n**STEP 6 — Post Comment & Close**\nUse the `jira_post_and_close` tool to post the formatted Extraction Results as a comment. This tool automatically transitions the ticket to Done for you.\n","maxIterations":"15"},"outputAnchors":[{"id":"toolAgent_0-output-toolAgent-AgentExecutor|BaseChain|Runnable","name":"toolAgent","label":"Tool Agent","type":"AgentExecutor | BaseChain | Runnable"}],"outputs":{},"selected":false},"width":300,"height":391,"positionAbsolute":{"x":1400,"y":301.6537131408828},"selected":false,"dragging":false},{"id":"chatOpenAI_0","position":{"x":909.1719048634138,"y":-230.96601898257785},"type":"customNode","data":{"id":"chatOpenAI_0","label":"ChatOpenAI","version":6,"name":"chatOpenAI","type":"ChatOpenAI","baseClasses":["ChatOpenAI","BaseChatModel","BaseLanguageModel"],"category":"Chat Models","description":"Wrapper around OpenAI large language models that use the Chat endpoint","inputParams":[{"label":"Connect Credential","name":"credential","type":"credential","credentialNames":["openAIApi"]},{"label":"Model Name","name":"modelName","type":"asyncOptions","loadMethod":"listModels","default":"gpt-4o"},{"label":"Temperature","name":"temperature","type":"number","step":0.1,"default":0.2,"optional":true}],"inputAnchors":[],"inputs":{"modelName":"gpt-4o","temperature":0.2},"outputAnchors":[{"id":"chatOpenAI_0-output-chatOpenAI-ChatOpenAI|BaseChatModel|BaseLanguageModel","name":"chatOpenAI","label":"ChatOpenAI","type":"ChatOpenAI | BaseChatModel | BaseLanguageModel"}],"outputs":{},"selected":false,"credential":"3fc10d3a-ba66-482f-bc0d-4acfabba573c"},"width":300,"height":476,"selected":false,"dragging":false,"positionAbsolute":{"x":909.1719048634138,"y":-230.96601898257785}},{"id":"buffe